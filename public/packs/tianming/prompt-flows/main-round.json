{
  "id": "mainRound",
  "$comment": "顺序：narratorFrame → cot-preamble(conditional) → mainRound → core → cot-no-thinking-guard(conditional) → cot-judge(conditional) → actionOptions* → historyFraming. CoT 相关模块通过 condition 字段实现 additive plugin 模式（PRINCIPLES §3.9）—— COT_ENABLED 时注入 thinking 指令; COT_DISABLED 时注入 thinking 禁令。narratorEnforcement 由 context-assembly 作为 post-history user message 追加。",
  "modules": [
    { "promptId": "narratorFrame", "role": "system", "order": -1, "depth": 0 },
    { "promptId": "cot-preamble", "role": "system", "order": -0.5, "depth": 1, "condition": "COT_ENABLED" },
    { "promptId": "cot-masquerade", "role": "assistant", "order": -0.4, "depth": 1, "condition": "COT_ENABLED" },
    { "promptId": "mainRound", "role": "system", "order": 0, "depth": 0 },
    { "promptId": "core", "role": "system", "order": 1, "depth": 0 },
    { "promptId": "cot-no-thinking-guard", "role": "system", "order": 1.1, "depth": 0, "condition": "COT_DISABLED" },
    { "promptId": "cot-judge", "role": "system", "order": 1.2, "depth": 0, "condition": "COT_JUDGE_ENABLED" },
    { "promptId": "presencePartition", "role": "system", "order": 1.5, "depth": 0, "condition": "NPC_PRESENCE_ENABLED" },
    { "promptId": "actionOptions", "role": "system", "order": 2, "depth": 0, "condition": "ACTION_OPTIONS_MODE_IS_ACTION" },
    { "promptId": "actionOptionsStory", "role": "system", "order": 2, "depth": 0, "condition": "ACTION_OPTIONS_MODE_IS_STORY" },
    { "promptId": "plotDirective", "role": "system", "order": 850, "depth": 1, "condition": "PLOT_DIRECTIVE" },
    { "promptId": "plotEvaluationStep2", "role": "system", "order": 851, "depth": 0, "condition": "PLOT_COMPLETION_HINT" },
    { "promptId": "historyFraming", "role": "system", "order": 10, "depth": 0 }
  ]
}
