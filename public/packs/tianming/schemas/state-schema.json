                "sceneArchive": { "生图历史": [], "当前壁纸图片ID": "" },
                "tasks": [],
                "persistentWallpaper": ""
              }
            }
          }
        },
        "nsfwMode": {
          "type": "boolean",
          "default": false,
          "$comment": "成人内容总开关。默认 false（安全默认）。开启时 AI 被要求为符合 nsfwGenderFilter 的 NPC 生成 私密信息，并为玩家生成 角色.身体。SettingsPanel UI 同步 localStorage aga_nsfw_settings 与此字段；开启后由 PrivacyProfileValidator 在 CommandExecutionStage 检测并触发 PrivacyProfileRepairPipeline 修复缺失字段。"
        },
        "nsfwGenderFilter": {
          "type": "string",
          "default": "female",
          "enum": ["all", "male", "female"],
          "$comment": "NSFW 性别过滤：哪些性别的 NPC 需要生成 私密信息。值移植自 demo nsfw.ts NsfwGenderFilter。仅影响生成/校验规则；不影响玩家 角色.身体（玩家始终生成，与 nsfwMode 同步）。"
        },
        "actionOptions": {
          "type": "object",
          "$comment": "行动选项生成模式。mode=action → 简短行为指令（actionOptions.md，8-20字）；mode=story → 剧情叙述分支（actionOptionsStory.md，150-450字）。pace=fast/slow 调节节奏倾向。SettingsPanel 将 localStorage 'aga_action_options_settings' 同步写入此字段；context-assembly 读取后派生 ACTION_OPTIONS_MODE_IS_* 条件变量，main-round / split-gen flows 据此加载对应 prompt。",
          "default": { "mode": "action", "pace": "fast", "customPrompt": "" },
          "properties": {
            "mode": {
              "type": "string",
              "enum": ["action", "story"],
              "default": "action",
              "$comment": "行动选项生成模式：action=行为导向（短）/ story=剧情导向（长）"
            },
            "pace": {
              "type": "string",
              "enum": ["fast", "slow"],
              "default": "fast",
              "$comment": "节奏倾向：fast=推进性 / slow=沉浸性，注入 prompt 变量 ACTION_PACE_HINT"
            },
            "customPrompt": {
              "type": "string",
              "default": "",
              "$comment": "用户自定义附加要求。非空时注入 prompt 变量 CUSTOM_ACTION_PROMPT"
            }
          }
        },
        "设置": {
          "type": "object",
          "$comment": "Runtime settings persisted to state tree. Read by pipeline stages.",
          "properties": {
            "cot": {
              "type": "object",
              "default": { "enabled": false, "judgeEnabled": false, "injectStep2": true, "reasoningRingSize": 3 }
            },
            "social": {
              "type": "object",
              "default": { "presenceEnabled": false }
            },
            "bodyPolish": {
              "type": "boolean",
              "default": false
            },
            "prompt": {
              "type": "object",
              "$comment": "Prompt generation settings — perspective, word count, style, etc. Managed by PromptPanel 游戏设定 tab.",
              "default": {
                "perspective": "第二人称",
                "wordCountRequirement": 650,
                "storyStyle": "general",
                "enableNoControl": true,
                "enableActionOptions": true,
                "actionOptionsMode": "action",
                "actionPace": "fast",
                "customSystemPrompt": ""
              }
            }
          }
        }
      }
    }
  }
